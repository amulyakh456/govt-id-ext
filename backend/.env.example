# Backend env variables. Copy to .env for local dev.

# Port the Express server binds. In production (Render) the platform injects
# PORT automatically — leave this set for local dev.
PORT=3011
HOST=127.0.0.1

# URL of the Python detection service. In production set this to the deployed
# detection-service URL (e.g. https://govt-id-detection.onrender.com).
DETECTION_URL=http://localhost:8005
DETECTION_TIMEOUT_MS=60000

# Allowed origin(s) for CORS. Comma-separated list. In production set this to
# the deployed frontend URL.
CORS_ORIGIN=http://localhost:5176

MAX_IMAGE_SIZE_MB=10
