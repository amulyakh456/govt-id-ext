# Frontend env variables. Copy to .env for local dev.
#
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# In dev, leave empty — vite.config.js proxies /api to the local backend.
# In a production build, set this to the deployed backend's origin
# (e.g. https://govt-id-backend.onrender.com).
VITE_API_URL=
